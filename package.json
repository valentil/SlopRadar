{
  "name": "slopradar-tests",
  "version": "1.0.0",
  "private": true,
  "description": "Local test suite + dev tooling for the SlopRadar extension",
  "scripts": {
    "test": "node run-tests.js",
    "report": "node build-report.js",
    "serve": "node serve-report.js",
    "package": "node ../package.js",
    "ship": "node run-tests.js && node build-report.js && node ../package.js --open",
    "watch": "node ../package.js --watch"
  },
  "dependencies": {
    "jsdom": "^24.0.0"
  }
}
