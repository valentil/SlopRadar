{
  "manifest_version": 3,
  "name": "SlopRadar AI Filter",
  "version": "1.0",
  "description": "Uses local Gemini Nano to remove generic AI marketing posts from social feeds.",
  "permissions": [
    "scripting"
  ],
  "host_permissions": [
    "*://*.linkedin.com/*",
    "*://*.x.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://*.linkedin.com/*", "*://*.x.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}