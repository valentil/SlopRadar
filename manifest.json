{
  "manifest_version": 3,
  "name": "SlopRadar AI Filter",
  "version": "1.3",
  "description": "Uses local Gemini Nano to remove generic AI marketing posts from social feeds.",
  "permissions": [
    "scripting",
    "tabs",
    "windows",
    "storage"
  ],
  "host_permissions": [
    "*://*.linkedin.com/*",
    "*://*.x.com/*",
    "*://*.twitter.com/*"
  ],
  "action": {
    "default_title": "SlopRadar",
    "default_popup": "options.html"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.linkedin.com/*",
        "*://*.x.com/*",
        "*://*.twitter.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
